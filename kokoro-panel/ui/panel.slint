import { Button, ComboBox, Slider, CheckBox, ProgressIndicator, Palette } from "std-widgets.slint";

// A labelled slider row: title on the left, live value on the right, slider below.
component SliderRow inherits VerticalLayout {
    in property <string> label;
    in property <string> value-text;
    in property <float> minimum;
    in property <float> maximum;
    in property <float> step;
    in property <bool> enabled: true;
    in-out property <float> value;
    callback changed(float);
    // Scratch: the current drag value snapped to `step`. Compared against `value`
    // so we only commit/persist on a real step change (see the Slider below).
    property <float> snapped;
    spacing: 3px;
    // Dim the whole row (label + readout + slider) when disabled.
    opacity: root.enabled ? 1.0 : 0.5;
    HorizontalLayout {
        Text { text: root.label; font-size: 13px; vertical-alignment: center; }
        Rectangle { horizontal-stretch: 1; }
        Text { text: root.value-text; font-size: 13px; color: #7a7a7a; vertical-alignment: center; }
    }
    Slider {
        enabled: root.enabled;
        minimum: root.minimum;
        maximum: root.maximum;
        step: root.step;
        value: root.value;
        // A drag fires `changed` per pixel; Slint's `step` only snaps keyboard/
        // scroll, not the drag. Snap the value ourselves and only propagate when
        // the snapped step actually changes — otherwise every sub-step mouse move
        // would re-set the value and re-write controls.json to disk (on the UI
        // thread), which makes the slider stutter and feel unresponsive.
        changed(v) => {
            root.snapped = root.step > 0
                ? root.minimum + Math.round((v - root.minimum) / root.step) * root.step
                : v;
            if root.snapped != root.value {
                root.value = root.snapped;
                root.changed(root.snapped);
            }
        }
    }
}

// The voice-Preview button: a borderless icon that flips between two modes.
// Idle it shows a blue play_circle; while a preview is playing (`previewing`)
// it shows a red stop_circle. Hover brightens the glyph to the full accent;
// missing model dims it. The glyph itself is the whole button (no box). The
// forwarded @children (a Tooltip) rides on top.
component PreviewButton inherits Rectangle {
    in property <bool> previewing;   // play (blue) vs stop (red)
    in property <bool> enabled: true; // model-ready gate; dims when off
    callback clicked;

    // Play uses the theme accent (same color as the sliders); stop is red.
    property <color> accent: root.previewing ? #ff4a3d : Palette.accent-background;

    // Size the button to the glyph so the hover hit-area doesn't extend past it
    // (a larger box would brighten the icon when hovering the empty padding).
    width: 30px;
    height: 30px;
    opacity: root.enabled ? 1.0 : 0.5;

    Image {
        // Google Material Symbols play_circle / stop_circle, Weight 100 (thin
        // outline). No box around it — the glyph itself is the button.
        source: root.previewing
            ? @image-url("stop-circle.svg")
            : @image-url("play-circle.svg");
        width: 30px;
        height: 30px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        // Idle == the accent exactly (matches the sliders); hover brightens.
        colorize: !root.enabled
            ? #888888
            : (touch.has-hover ? root.accent.brighter(0.2) : root.accent);
        animate colorize { duration: 130ms; }
    }
    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
        clicked => { root.clicked(); }
    }
    @children
}

// A tiny animated voice meter: six rounded bars that ripple up and down like an
// audio equalizer. Driven by `animation-tick()`, so it animates only while it's on
// screen (the "ready" state) and costs nothing otherwise. Each bar is phase-offset
// from its neighbour, giving a travelling-wave look.
component Waveform inherits Rectangle {
    min-width: 48px;
    max-width: 48px;
    min-height: 20px;
    max-height: 20px;
    // Bar colour follows its height: a short bar sits at the base green, a tall one
    // lifts toward a light green (mix factor = weight of `lo`, so 1 = short/lo).
    property <color> lo: #2e8b40;
    property <color> hi: #7cfc00; // Lawn Green
    for _bar[i] in [0, 1, 2, 3, 4, 5]: Rectangle {
        width: 4px;
        x: i * 7px;
        // 1.3 cycles/sec, each bar 52° behind the last → a rolling wave.
        height: 5px + 13px * (1 + Math.sin(animation-tick() / 1s * 468deg + i * 52deg)) / 2;
        y: parent.height - self.height;
        border-radius: 2px;
        background: root.lo.mix(root.hi, 1.0 - (self.height - 5px) / 13px);
    }
}

export component AppWindow inherits Window {
    title: "Kokoro Kindle Reader — Settings";
    icon: @image-url("../../icons/128x128.png");
    preferred-width: 400px;
    preferred-height: 600px;
    // Floor of the narrator row: accent (100, fits "American") + gender (90,
    // fits "Female") + name (~120 min before its chevron clips) + 16 spacing +
    // 40 padding (symmetric 20px each side). Narrower and the chevron spills.
    min-width: 400px;

    // --- state (set from Rust) ---
    // Narrator as three cascading dropdowns: accent x gender selects the name list.
    in property <[string]> accents;
    in property <[string]> genders;
    in property <[string]> names;
    in-out property <int> accent-index;
    in-out property <int> gender-index;
    in-out property <int> name-index;
    in-out property <float> speed;
    in-out property <float> gain;
    in-out property <float> chunk;
    in-out property <bool> kindle-kokoro;
    in property <bool> model-ready;
    in property <bool> downloading;
    in property <float> download-frac;
    in property <string> download-label;
    in property <bool> verifying;
    in property <float> verify-frac;
    in property <bool> previewing;
    in property <string> status;

    // --- events (handled in Rust) ---
    callback accent-changed(int);
    callback gender-changed(int);
    callback name-changed(int);
    callback speed-changed(float);
    callback gain-changed(float);
    callback chunk-changed(float);
    callback download-clicked();
    callback kindle-toggled(bool);
    callback preview-clicked();

    VerticalLayout {
        padding: 20px;
        spacing: 16px;
        alignment: start;

        // Model status card — a subtle surface that adapts to the light/dark theme
        // (a faint tint of the foreground over the window background).
        Rectangle {
            background: Palette.foreground.transparentize(0.94);
            border-radius: 2px;
            border-width: 1px;
            border-color: Palette.border;
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                if root.downloading: VerticalLayout {
                    spacing: 8px;
                    Text { text: root.download-label; font-size: 12px; }
                    ProgressIndicator { progress: root.download-frac; height: 6px; }
                }
                // Startup integrity check: a determinate bar of how much of the
                // model/voice data has been hashed so far.
                if !root.downloading && root.verifying: VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: "Checking model files — \{Math.round(root.verify-frac * 100)}%";
                        font-size: 12px;
                    }
                    ProgressIndicator { progress: root.verify-frac; height: 6px; }
                }
                if !root.downloading && !root.verifying && !root.model-ready: HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: "Model not downloaded (~420 MB).";
                        color: #b0701a;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Button { text: "Download"; primary: true; clicked => { root.download-clicked(); } }
                }
                if !root.downloading && !root.verifying && root.model-ready: HorizontalLayout {
                    spacing: 10px;
                    alignment: start;
                    Waveform { }
                    Text {
                        text: "Voice Engine Ready";
                        color: #7cfc00; // Lawn Green
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Kindle toggle with the voice Preview button right beside it. `alignment:
        // start` packs them left at their natural sizes (otherwise the checkbox
        // stretches and shoves the button to the far edge).
        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            CheckBox {
                // Drives auto-injection: the host's Kindle-watcher reads this flag
                // (kindle_kokoro in controls.json) and injects the Kokoro hook on Kindle's
                // next launch. Two-way (<=>) keeps property and widget in sync.
                text: "Narrate Kindle with Kokoro";
                checked <=> root.kindle-kokoro;
                toggled => { root.kindle-toggled(self.checked); }
            }
            // Outlined play/stop Preview button, right next to the checkbox. Stays
            // interactive during preview (red stop on hover); missing model dims it.
            PreviewButton {
                previewing: root.previewing;
                enabled: root.model-ready && root.kindle-kokoro;
                clicked => { root.preview-clicked(); }
                // Label lives in a hover tooltip. Tooltip.text is styled-text,
                // so wrap the literal in @markdown.
                Tooltip { text: @markdown("Preview voice"); }
            }
        }

        // Narrator: accent x gender -> name, all three on one row.
        VerticalLayout {
            spacing: 6px;
            Text {
                text: "Narrator";
                font-size: 13px;
                vertical-alignment: center;
                opacity: root.kindle-kokoro ? 1.0 : 0.5; // dim heading with its dropdowns
            }
            HorizontalLayout {
                spacing: 8px;
                // Accent / gender are short — size them to content; the name list
                // takes the remaining width.
                ComboBox {
                    model: root.accents;
                    current-index <=> root.accent-index;
                    enabled: root.kindle-kokoro;
                    width: 120px;
                    selected => { root.accent-changed(self.current-index); }
                }
                ComboBox {
                    model: root.genders;
                    current-index <=> root.gender-index;
                    enabled: root.kindle-kokoro;
                    width: 100px;
                    selected => { root.gender-changed(self.current-index); }
                }
                ComboBox {
                    model: root.names;
                    current-index <=> root.name-index;
                    enabled: root.kindle-kokoro;
                    horizontal-stretch: 1;
min-width: 100px;
                    selected => { root.name-changed(self.current-index); }
                }
            }
        }

        // Sliders
        SliderRow {
            label: "Reading Speed";
            value-text: "\{Math.round(root.speed * 100)}%";
            minimum: 0.5;
            maximum: 2.0;
            step: 0.10; // 10% increments
            enabled: root.kindle-kokoro;
            value <=> root.speed;
            changed(v) => { root.speed-changed(v); }
        }
        SliderRow {
            label: "Volume";
            value-text: "\{Math.round(root.gain * 100)}%";
            minimum: 0.0;
            maximum: 2.0;
            step: 0.10; // 10% increments
            enabled: root.kindle-kokoro;
            value <=> root.gain;
            changed(v) => { root.gain-changed(v); }
        }
        SliderRow {
            label: "Sentences per chunk";
            value-text: "\{Math.round(root.chunk)}";
            minimum: 1.0;
            maximum: 8.0;
            step: 1.0;
            enabled: root.kindle-kokoro;
            value <=> root.chunk;
            changed(v) => { root.chunk-changed(v); }
        }

        Rectangle { vertical-stretch: 1; }

        if root.status != "": Text {
            text: root.status;
            font-size: 12px;
            color: #5a5a5a;
            wrap: word-wrap;
        }

        Text {
            text: "Keep Kokoro Kindle Reader running (tray) for Kindle to narrate.";
            font-size: 11px;
            color: #a0a0a0;
            wrap: word-wrap;
        }
    }
}
